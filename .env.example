# CSFloat
# Fuer lokale Entwicklung einen gueltigen API-Key eintragen.
# Kann auch ueber die Settings-UI gesetzt werden (verschluesselt uebertragen).
CSFLOAT_API_KEY="replace-with-csfloat-api-key"

# Verschluesselung fuer API-Key Uebertragung (mindestens 32 Zeichen)
# WICHTIG: Dieser Key muss identisch sein zwischen Frontend (build-time) und Backend
ENCRYPTION_KEY="change-this-to-a-32-char-secret-key!!"

# Debug / Observability
DEBUG=false
OBSERVABILITY_ENABLED=true
OBSERVABILITY_EVENTS_API_ENABLED=false
OBSERVABILITY_FRONTEND_TELEMETRY_ENABLED=true
OBSERVABILITY_RETENTION_DAYS=30

# Security (Server)
# Erlaubte CORS-Origin(s), komma-separiert, z.B.:
# CORS_ALLOWED_ORIGINS=https://cs2.clustercontrol.cc,https://app.example.com
CORS_ALLOWED_ORIGINS=
# In Produktion auf true setzen, damit nur konfigurierte Origins + (optional) same-host erlaubt sind.
CORS_STRICT_MODE=true
CORS_ALLOW_SAME_HOST=true
CORS_ALLOW_LOCALHOST=false

# HTTP Rate Limits fuer sensitive Endpunkte (Auth/Sync)
# Mit 0 kann ein einzelnes Limit deaktiviert werden.
SECURITY_RATE_LIMIT_ENABLED=true
RATE_LIMIT_SYNC_PUSH_PER_MINUTE=60
RATE_LIMIT_SYNC_PULL_PER_MINUTE=180
RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=20
RATE_LIMIT_AUTH_CALLBACK_PER_MINUTE=40
RATE_LIMIT_AUTH_VALIDATE_PER_MINUTE=240
RATE_LIMIT_AUTH_INVENTORY_PER_MINUTE=60

# Datenbank (docker-compose + Backend)
DB_HOST=db
DB_NAME=portfolio
DB_USER=portfolio
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root
DB_CHARSET=utf8

# Desktop PHP-Sidecar: wenn DB_HOST fuer Docker "db" ist, nutzt Electron lokal automatisch 127.0.0.1.
# Optional explizit setzen, falls deine lokale DB anders erreichbar ist.
# DESKTOP_DB_HOST=127.0.0.1

# Frontend API-Basis (optional)
# Default im Frontend ist: ${window.location.origin}/api/index.php
# VITE_API_BASE_URL="http://localhost:8080/api/index.php"

# CS Updates Realtime (WebSocket)
# false = nur REST Polling (empfohlen, wenn kein separater WS-Gateway deployed ist)
# true  = versucht Realtime via /ws/updates
VITE_CS_UPDATES_WS_ENABLED=false

# CS Updates Banner Sichtbarkeit (Stunden seit letztem Update, danach ausblenden)
# Default: 168 (7 Tage), Min: 1, Max: 720 (30 Tage)
CS_UPDATES_BANNER_DURATION_HOURS=168

# App/CasaOS Konfiguration fuer docker-compose Interpolation
APP_HOST=127.0.0.1
APP_PORT=8080
PMA_PORT=8081

# Web-Container Image (GitHub Container Registry)
WEB_IMAGE=ghcr.io/control-ger/csportfoliotracking-web:latest
WEB_PULL_POLICY=always

# Pfade fuer Docker Bind-Mounts
# Linux/CasaOS Beispiel:
PROJECT_ROOT_PATH=/path/to/CsPortfolioTracking

