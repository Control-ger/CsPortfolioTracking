<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # API-Routen muessen direkt an PHP gehen
    RewriteCond %{REQUEST_URI} ^/api/ [NC]
    RewriteRule ^ - [L]

    # Existierende Dateien/Verzeichnisse normal ausliefern
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # SPA-Fallback fuer React Router (z.B. /auth/callback)
    RewriteRule ^ /index.html [L]
</IfModule>
