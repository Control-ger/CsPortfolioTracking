<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Route-relative Asset-URLs (z.B. /auth/assets/...) auf Root-Assets umbiegen.
    RewriteRule ^.+/assets/(.+)$ /assets/$1 [L,NC]
    RewriteRule ^.+/(icon\.png|icon\.ico|manifest\.json|sw\.js)$ /$1 [L,NC]

    # API-Routen muessen direkt an PHP gehen
    RewriteCond %{REQUEST_URI} ^/api/ [NC]
    RewriteRule ^ - [L]

    # Asset-Requests niemals auf index.html umbiegen.
    # Wenn ein Asset fehlt, soll sauber 404 kommen (statt text/html).
    RewriteRule ^assets/ - [L,NC]
    RewriteRule ^.+\.(?:js|mjs|css|map|json|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf|eot)$ - [L,NC]

    # Existierende Dateien/Verzeichnisse normal ausliefern
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # SPA-Fallback fuer React Router (z.B. /auth/callback)
    RewriteRule ^ /index.html [L]
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "^index\.html$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0, s-maxage=0"
        Header set Surrogate-Control "no-store"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    <Files "sw.js">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0, s-maxage=0"
        Header set Surrogate-Control "no-store"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </Files>

    <FilesMatch "\.(?:js|mjs|css|map|png|jpg|jpeg|gif|webp|svg|ico|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    Header always set X-Content-Type-Options "nosniff"
</IfModule>
